<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/tess/pricing/categories" method="GET">
        <service class="Tess\PricingTool\Api\CategoryManagementInterface" method="getList" />
        <resources>
            <resource ref="Tess_PricingTool::read" />
        </resources>
    </route>

    <route url="/V1/tess/pricing/filters" method="GET">
        <service class="Tess\PricingTool\Api\FilterManagementInterface" method="getOptions" />
        <resources>
            <resource ref="Tess_PricingTool::read" />
        </resources>
    </route>

    <route url="/V1/tess/pricing/products" method="GET">
        <service class="Tess\PricingTool\Api\ProductManagementInterface" method="getList" />
        <resources>
            <resource ref="Tess_PricingTool::read" />
        </resources>
    </route>

    <route url="/V1/tess/pricing/products/:sku" method="GET">
        <service class="Tess\PricingTool\Api\ProductManagementInterface" method="getBySku" />
        <resources>
            <resource ref="Tess_PricingTool::read" />
        </resources>
    </route>
</routes>
